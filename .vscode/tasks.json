            "presentation": {
                "reveal": "never",
                "panel": "shared"
            },
            "problemMatcher": [],
            "detail": "Launch the agent dashboard in a separate terminal window __agent-system__"
        },
        {
            "label": "[agent] Maintenance Audit",
            "type": "shell",
            "command": "H:\\development\\projects\\AgentRunner\\.venv\\Scripts\\python.exe",
