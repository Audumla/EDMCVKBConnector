#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# Find Python
py="$repo_root/.venv/Scripts/python.exe"
if [ ! -x "$py" ]; then
  py="python"
fi

# Rebuild CHANGELOG.md after any merge to ensure consistency across branches
# BUT skip this if we just merged a release-please branch, as we want to keep
# the officially stamped version from the cloud.
is_release_merge=$(git log -1 --pretty=%s | grep -iE "release-please|release v[0-9]" || true)
if [ -z "$is_release_merge" ]; then
  "$py" "$repo_root/scripts/changelog/build_changelog.py"
fi

# Release-specific automation (only on main branch)
branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
if [ "$branch" == "main" ]; then
  log_dir="$repo_root/agent_artifacts/codex/temp"
  mkdir -p "$log_dir"

  nohup "$py" "$repo_root/scripts/auto_pull_after_release.py" \
    --branch main \
    --remote origin \
    --poll-seconds 15 \
    --timeout-seconds 1800 \
    >>"$log_dir/auto_pull_after_release.log" 2>&1 &
fi

exit 0

