{
  "name": "gemini-api",
  "provider": {
    "provider_type": "api_keyed",
    "available_models": ["gemini-2.5-pro", "gemini-2.5-flash"],
    "usage": {
      "quick_static": {"status": "API", "display": "Configured via API key"},
      "detailed_command": ["python", "-V"],
      "timeout_sec": 10
    }
  },
  "planner": {
    "enabled": false,
    "test_enabled": false,
    "model": "gemini-2.5-flash",
    "thinking_budget": "none"
  },
  "executor": {
    "enabled": false,
    "test_enabled": false,
    "model": "gemini-2.5-flash",
    "runner": "runners/run_openai_api_plan.py",
    "runner_args": [
      "--base-url",
      "https://generativelanguage.googleapis.com/v1beta/openai",
      "--api-key-env",
      "GEMINI_API_KEY"
    ]
  }
}
