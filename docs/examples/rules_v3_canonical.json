[
  {
    "title": "All Rule - Gear Down",
    "enabled": true,
    "when": {
      "all": [
        { "signal": "gear_down", "op": "eq", "value": true }
      ]
    },
    "then": [
      { "type": "vkb_set_shift", "tokens": ["Subshift3"] }
    ],
    "else": [
      { "type": "vkb_clear_shift", "tokens": ["Subshift3"] }
    ]
  },
  {
    "title": "Any Rule - Map Open",
    "enabled": true,
    "when": {
      "any": [
        { "signal": "gui_focus", "op": "in", "value": ["GalaxyMap", "SystemMap"] },
        { "signal": "gui_focus", "op": "eq", "value": "Codex" }
      ]
    },
    "then": [
      { "type": "vkb_set_shift", "tokens": ["Shift1"] }
    ],
    "else": [
      { "type": "vkb_clear_shift", "tokens": ["Shift1"] }
    ]
  },
  {
    "title": "Combined Rule - Combat Setup",
    "enabled": true,
    "when": {
      "all": [
        { "signal": "landing_gear", "op": "eq", "value": "up" }
      ],
      "any": [
        { "signal": "hardpoints", "op": "eq", "value": "deployed" },
        { "signal": "in_danger", "op": "eq", "value": true }
      ]
    },
    "then": [
      { "type": "vkb_set_shift", "tokens": ["Shift2"] }
    ],
    "else": [
      { "type": "vkb_clear_shift", "tokens": ["Shift2"] }
    ]
  }
]
